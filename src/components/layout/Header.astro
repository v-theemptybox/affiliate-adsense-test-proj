---
import { SITE } from '@/config/site';

const navLinks = [
  { href: '/blog', label: 'Ideas' },
  { href: '/reviews', label: 'Reviews' },
  { href: '/best', label: 'Best Picks' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b" style="border-color: var(--color-border);">
  <nav class="container flex items-center justify-between h-16">

    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="text-2xl">🏡</span>
      <span style="font-family:'Playfair Display',Georgia,serif; font-weight:700; font-size:1.2rem; color:var(--color-text);">
        {SITE.name}
      </span>
    </a>

    <ul class="hidden md:flex items-center gap-7 list-none p-0 m-0">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a href="/search" aria-label="Search" class="no-underline" style="color:var(--color-muted);">
        <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </a>
      <button id="mobile-menu-btn" class="md:hidden" aria-label="Menu" style="color:var(--color-muted);">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t" style="border-color:var(--color-border); background:var(--color-bg);">
    <ul class="container py-4 space-y-3 list-none p-0 px-4">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block text-sm font-medium py-1 no-underline" style="color:var(--color-text);">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
