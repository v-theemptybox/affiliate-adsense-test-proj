---
export const prerender = true;
import BaseLayout from '@/layouts/BaseLayout.astro';
import Card from '@/components/common/Card.astro';
import AdBanner from '@/components/ads/AdBanner.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.noindex)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());
---

<BaseLayout title="Blog" description="Tips, guides, and how-tos for making better buying decisions.">
  <div class="container py-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Blog</h1>
    <p class="text-gray-500 mb-8">Tips, guides, and in-depth articles.</p>
    <AdBanner />
    <div class="card-grid mt-8">
      {posts.map(post => (
        <Card
          title={post.data.title}
          description={post.data.description}
          href={`/blog/${post.id}`}
          image={post.data.image}
          date={post.data.publishedAt}
        />
      ))}
    </div>
    {posts.length === 0 && (
      <p class="text-gray-400 text-center py-20">No articles yet. Check back soon.</p>
    )}
  </div>
</BaseLayout>
